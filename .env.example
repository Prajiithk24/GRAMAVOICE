# Local default DB (H2 file)
GRAMAVOICE_DB_URL=jdbc:h2:file:./data/gramavoice;DB_CLOSE_ON_EXIT=FALSE;MODE=MySQL
GRAMAVOICE_DB_USERNAME=sa
GRAMAVOICE_DB_PASSWORD=

# If you want local MySQL instead, use:
# GRAMAVOICE_DB_URL=jdbc:mysql://localhost:3306/gramavoice?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Kolkata
# GRAMAVOICE_DB_USERNAME=root
# GRAMAVOICE_DB_PASSWORD=root

SERVER_PORT=8080
VITE_PROXY_TARGET=http://localhost:8080
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_MODEL=sarvam-30b
SARVAM_ENABLED=true
APP_AUTH_SECRET=replace-with-a-long-random-secret
